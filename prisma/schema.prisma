generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String        @id @default(cuid())
  supabaseId   String        @unique
  email        String        @unique
  name         String?
  avatarUrl    String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  cvs          CV[]
  subscription Subscription?
  settings     UserSettings?

  @@map("users")
}

model UserSettings {
  id         String   @id @default(cuid())
  userId     String   @unique
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // CV preferences
  cvLanguage String   @default("en")
  cvFont     String   @default("Inter")
  cvColor    String   @default("#4f46e5")
  cvFormat   String   @default("A4")
  showSummary     Boolean @default(true)
  showProjects    Boolean @default(true)
  showSkills      Boolean @default(true)
  showInterests   Boolean @default(false)

  // AI preferences
  aiTone     String   @default("professional")
  aiLength   String   @default("medium")
  aiLanguage String   @default("en")
  aiStyle    String   @default("corporate")

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("user_settings")
}

model CV {
  id               String     @id @default(cuid())
  userId           String
  title            String
  template         CVTemplate @default(BASIC)
  status           CVStatus   @default(DRAFT)
  name             String
  jobTitle         String
  email            String?
  phone            String?
  location         String?
  website          String?
  linkedin         String?
  github           String?
  portfolio        String?
  summary          String?    @db.Text
  experience       Json       @default("[]")
  education        Json       @default("[]")
  skills           Json       @default("[]")
  projects         Json       @default("[]")
  languages        Json       @default("[]")
  certifications   Json       @default("[]")
  generatedContent String?    @db.Text
  atsScore         Int?
  coverLetter      String?    @db.Text
  isPublic         Boolean    @default(false)
  viewCount        Int        @default(0)
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt
  user             User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("cvs")
}

model Subscription {
  id                     String             @id @default(cuid())
  userId                 String             @unique
  stripeCustomerId       String?            @unique
  stripeSubscriptionId   String?            @unique
  stripePriceId          String?
  stripeCurrentPeriodEnd DateTime?
  plan                   SubscriptionPlan   @default(FREE)
  status                 SubscriptionStatus @default(ACTIVE)
  createdAt              DateTime           @default(now())
  updatedAt              DateTime           @updatedAt
  user                   User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("subscriptions")
}

enum CVTemplate {
  BASIC
  MODERN
  EXECUTIVE
}

enum CVStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum SubscriptionPlan {
  FREE
  PRO
}

enum SubscriptionStatus {
  ACTIVE
  CANCELED
  PAST_DUE
  INCOMPLETE
}
