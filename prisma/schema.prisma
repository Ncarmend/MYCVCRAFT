// Prisma schema for AI CV Generator SaaS
// Database: PostgreSQL (Supabase)

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}





model User {
  id         String   @id @default(cuid())
  supabaseId String   @unique // Supabase Auth user ID
  email      String   @unique
  name       String?
  avatarUrl  String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  cvs          CV[]
  subscription Subscription?
  settings UserSettings?


  @@map("users")
}

model CV {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  title    String
  template CVTemplate @default(BASIC)
  status   CVStatus   @default(DRAFT)

  // Personal information
  name     String
  photoUrl  String?
  jobTitle String
  email    String?
  phone    String?
  location String?
  website  String?
  linkedin  String?
  github    String?
  portfolio String?
  summary   String?  @db.Text

  // Structured content (stored as JSON)
  experience     Json @default("[]")
  education      Json @default("[]")
  skills         Json @default("[]")
  projects       Json @default("[]")
  languages      Json @default("[]")
  certifications Json @default("[]")

  // AI-generated content
  generatedContent String? @db.Text
  atsScore         Int?
  coverLetter      String? @db.Text

  // Metadata
  isPublic  Boolean @default(false)
  viewCount Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@map("cvs")
}

model Subscription {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  stripeCustomerId       String?            @unique
  stripeSubscriptionId   String?            @unique
  stripePriceId          String?
  stripeCurrentPeriodEnd DateTime?

  plan   SubscriptionPlan   @default(FREE)
  status SubscriptionStatus @default(ACTIVE)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("subscriptions")
}

enum CVTemplate {
  BASIC
  MODERN
  EXECUTIVE
  CREATIVE
  MINIMAL
  ELEGANT
  TECH
  CORPORATE
}

enum CVStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum SubscriptionPlan {
  FREE
  PRO
}

enum SubscriptionStatus {
  ACTIVE
  CANCELED
  PAST_DUE
  INCOMPLETE
}

model UserSettings {
  id            String   @id @default(cuid())
  userId        String   @unique
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // CV Settings
  cvLanguage    String   @default("fr")
  cvFont        String   @default("Inter")
  cvColor       String   @default("#111827")
  cvFormat      String   @default("A4")

  showSummary   Boolean  @default(true)
  showProjects  Boolean  @default(true)
  showSkills    Boolean  @default(true)
  showInterests Boolean  @default(false)

  // AI Settings
  aiTone        String   @default("professional")
  aiLength      String   @default("medium")
  aiLanguage    String   @default("fr")
  aiStyle       String   @default("corporate")

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("user_settings")
}
